{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimeliq.de/schema/heimeliq.schema.json",
  "title": "heimeliQ Manifest",
  "description": "Projektspezifische Erweiterungen, die das OKH-Manifest ergänzen.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "heimeliq-template-version",
    "version",
    "slug",
    "series",
    "type",
    "status",
    "forest"
  ],
  "properties": {
    "heimeliq-template-version": {
      "description": "SemVer-Version der heimeliQ-Vorlage, auf der dieses Repo basiert.",
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "version": {
      "description": "SemVer-Version dieses Möbels.",
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "slug": {
      "description": "URL-Slug, identisch mit dem Repo-Namen ohne 'heimeliq-' Präfix. Schema: <reihe>-<waldname>.",
      "type": "string",
      "pattern": "^(massiq|workaholiq|keiliq)-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "series": {
      "description": "Reihe, zu der dieses Möbel gehört.",
      "type": "string",
      "enum": ["massiq", "workaholiq", "keiliq"]
    },
    "type": {
      "description": "Möbel-Typ als Metadatenfeld für Filter/Suche. Kein Teil der ID. Beispiele: 'sideboard', 'werkbank', 'werkzeughalter'.",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tags": {
      "description": "Weitere Schlagworte für Filter und Suche.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "status": {
      "description": "Veröffentlichungsstatus.",
      "type": "string",
      "enum": ["draft", "published", "archived"]
    },
    "forest": {
      "description": "Wald-Namensgeber dieses Möbels. Jedes Möbel trägt den Namen eines real existierenden Waldes; der Waldname ist möbel-eindeutig.",
      "type": "object",
      "required": ["id", "name", "region", "country"],
      "properties": {
        "id": {
          "description": "URL-taugliche Kurzform des Waldnamens, identisch mit dem letzten Segment des Repo-Namens.",
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "description": "Vollständiger Name des Waldes (mit Umlauten/Sonderzeichen, menschenlesbar).",
          "type": "string",
          "minLength": 2
        },
        "region": {
          "description": "Region innerhalb des Landes.",
          "type": "string"
        },
        "country": {
          "description": "Land im ISO-3166-1-alpha-2-Format.",
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "forest_type": {
          "description": "Wald-Typus (z. B. Mischwald, Nadelwald, Regenwald, Urwald).",
          "type": "string"
        },
        "age_estimate_years": {
          "description": "Grobe Altersangabe des Waldes (Jahre).",
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "description": "Schutz-/Bedrohungsstatus.",
          "type": "string",
          "enum": ["protected", "partially-protected", "endangered", "critically-endangered", "stable", "unknown"]
        },
        "themes": {
          "description": "Stichworte zur Geschichte/Bedeutung (z. B. 'braunkohle', 'biodiversität', 'klimaschutz').",
          "type": "array",
          "items": { "type": "string" }
        },
        "links": {
          "description": "Weiterführende Links, z. B. zu Schutzorganisationen oder Wikipedia.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "note": {
          "description": "Optionaler Satz, warum genau dieser Wald für genau dieses Möbel.",
          "type": "string"
        }
      }
    },
    "external_parts": {
      "description": "Externe Drittteile (nicht open source).",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heimeliq-part-id", "name", "quantity"],
        "properties": {
          "heimeliq-part-id": {
            "type": "string",
            "pattern": "^E[0-9]{3}$"
          },
          "name": { "type": "string" },
          "standard": { "type": "string" },
          "material": { "type": "string" },
          "dimensions": { "type": "string" },
          "manufacturer": { "type": "string" },
          "manufacturer_article_number": { "type": "string" },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "suppliers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "wood_options": {
      "description": "Holzarten, in denen das Möbel konstruktiv möglich ist.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["species"],
        "properties": {
          "species": { "type": "string" },
          "origin": { "type": "string" },
          "recommended": { "type": "boolean" }
        }
      }
    },
    "care": {
      "type": "object",
      "properties": {
        "surface_treatment": { "type": "string" },
        "recommended_products": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "sustainability": {
      "type": "object",
      "properties": {
        "wood_source": { "type": "string" },
        "co2_documented": { "type": "boolean" }
      }
    }
  }
}
